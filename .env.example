# Скопируйте этот файл в `.env` (рядом с pyproject.toml) и подставьте свои значения.
# Файл `.env` в Git не коммитится.

# --- Telegram Bot API ---
TELEGRAM_BOT_TOKEN=

# Временный запасной вариант (только разработка / пока нет интеграции):
# куда слать первое уведомление об опросе по документам, если ещё не настроены
# POST …/examination/telegram/bindings и в HR нет telegram у сотрудника.
# Подставьте свой числовой chat_id (личный чат с ботом). В проде обычно не нужен.
TELEGRAM_DOCS_SURVEY_FALLBACK_CHAT_ID=

# URL текста согласия на обработку ПДн (подставляется в первое Telegram-уведомление Part1).
# Пусто — в тексте будет «(здесь будет ссылка)».
# DOCS_SURVEY_CONSENT_DOCUMENT_URL=https://example.org/consent-pdn

# Чат отдела кадров в Telegram (числовой chat_id): уведомление при отказе от согласия ПДн или молчании 10 минут.
# TELEGRAM_DOCS_SURVEY_HR_NOTIFY_CHAT_ID=

# За сколько минут до выбранного слота опроса по документам отправить напоминание «готов / не готов» (окно ±1 мин).
# DOCS_SURVEY_REMINDER_MINUTES_BEFORE=30

# Имя, отчество и должность в тексте сообщения сюда НЕ вписываются —
# они подставляются из ядра HR (карточка сотрудника). Если в уведомлении «коллега»
# и прочерк в должности, проверьте данные сотрудника и app.hr.get_employee, а не .env.

# 1 = включить long polling (нужен для inline-кнопок; иначе webhook).
TELEGRAM_ENABLE_POLLING=0

# Где крутить getUpdates: 1 = внутри процесса uvicorn (проще, но при --reload возможен кратковременный 409).
# 0 = только API в uvicorn; бот запускать отдельно: python -m skill_assessment.telegram_worker (из каталога ядра, venv).
# TELEGRAM_POLLING_RUN_IN_UVICORN=1

# Опционально: без POST /telegram/bindings — подставить client_id и employee_id для локального теста сценария.
# TELEGRAM_DEV_CLIENT_ID=demo_client
# TELEGRAM_DEV_EMPLOYEE_ID=demo_emp
