# Скопируйте в `.env` (рядом с pyproject.toml). `.env` в Git не коммитится.
# Ниже — примеры значений для локальной разработки (кроме токена: подставьте свой из @BotFather).
#
# --- Куда уходит запрос ПДн (Part 1) — один приоритет, без «угадываний» ---
# 1) Привязка POST …/examination/telegram/bindings (client_id + employee_id → chat_id) — если есть, бьёт всё остальное.
# 2) Поле Telegram у сотрудника в HR (ядро).
# 3) TELEGRAM_DOCS_SURVEY_FALLBACK_CHAT_ID — только если (1) и (2) пусты. Число без точек: 300398364, не 300.398.364.
# Куда уходят таймауты/отказы для кадров — отдельно: TELEGRAM_DOCS_SURVEY_HR_NOTIFY_CHAT_ID (может совпадать с вашим личным чатом, но это другая переменная).
# После старта сессии в логе сервера ищите строку: docs_survey: сессия … → sendMessage chat_id=… (источник: …).

# Telegram Bot API (бот @… или другой). Только плейсхолдер — замените на реальный токен.
TELEGRAM_BOT_TOKEN=1234567890:AA-REPLACE-WITH-TOKEN-FROM-BOTFATHER

# Исходящие sendMessage: таймаут (сек) и число попыток при 429/5xx и сетевых сбоях (перегрузка / Telegram медленный).
# TELEGRAM_HTTP_TIMEOUT_SECONDS=45
# TELEGRAM_SEND_MAX_ATTEMPTS=3

# При 1 — уведомление о ПДн при POST /sessions/{id}/start уходит в фоне (быстрый ответ API; сообщение через секунды).
# Полезно при перегруженном uvicorn, иначе клиент может оборвать запрос до ответа Telegram.
# SKILL_ASSESSMENT_DOCS_SURVEY_TELEGRAM_BACKGROUND=1

TELEGRAM_ENABLE_POLLING=1
# Локально с uvicorn --reload: держите 0 и запускайте один раз python -m skill_assessment.telegram_worker (один getUpdates).
# 1 = polling внутри uvicorn — только без reload или когда готовы к 409 при перезапуске воркера.
TELEGRAM_POLLING_RUN_IN_UVICORN=0

# Временный chat_id (личный чат с ботом), если нет привязки POST …/examination/telegram/bindings и нет telegram в HR — подставьте свой (узнать: @userinfobot).
TELEGRAM_DOCS_SURVEY_FALLBACK_CHAT_ID=123456789
# TELEGRAM_DOCS_SURVEY_DISALLOW_FALLBACK=1 — не отправлять запрос ПДн без личного chat_id сотрудника (иначе тихий fallback → таймаут «не ответил», а сотрудник ничего не видел).
TELEGRAM_DOCS_SURVEY_HR_NOTIFY_CHAT_ID=123456789
# 1 (по умолчанию): не слать HR-таймауты в тот же chat_id, куда шли сообщения сотруднику (иначе «мусор» в чате экзаменуемого).
# TELEGRAM_DOCS_SURVEY_SUPPRESS_HR_NOTIFY_TO_EMPLOYEE_CHAT=1

# Публичный базовый URL (без / в конце). Для кликабельных ссылек из Telegram на телефоне задайте HTTPS туннеля к порту API.
# Примеры: ngrok http 8000 · npx localtunnel --port 8000 (URL в консоли; при каждом запуске новый).
# http://127.0.0.1:8000 оставьте только если ссылки с телефона не нужны — в Telegram они тогда не подставляются как абсолютные.
SKILL_ASSESSMENT_PUBLIC_BASE_URL=http://127.0.0.1:8000
#
# --- Шаблоны ссылок (скопируйте в браузер или в письмо; подставьте свой хост и token) ---
# 1) В .env задайте тот же хост, что в ngrok, например:
#    SKILL_ASSESSMENT_PUBLIC_BASE_URL=https://abcd-12-34-56-78.ngrok-free.app
# 2) Чек-лист документов Part 1 для сотрудника (token выдаётся в сессии / API как part1_docs_checklist_token):
#    https://abcd-12-34-56-78.ngrok-free.app/api/skill-assessment/ui/part1-docs-checklist?token=REPLACE_WITH_YOUR_TOKEN
#    (одной строкой, без переноса; REPLACE_WITH_YOUR_TOKEN замените на реальный токен из интерфейса HR или ответа API)
# 3) Страница оценки руководителя Part 3 (token выдаётся в сессии / API как manager_assessment_token):
#    https://abcd-12-34-56-78.ngrok-free.app/api/skill-assessment/ui/manager-assessment?token=REPLACE_WITH_YOUR_TOKEN
#    (ссылка отправляется руководителю в Telegram после завершения кейсов)

# --- Протокол экзамена в Telegram (после завершения, задержка TELEGRAM_EXAM_PROTOCOL_DELAY_SEC, по умол. 300 с) ---
# Канал кадров / админ: бот — администратор канала; id вида -100…
# TELEGRAM_EXAM_PROTOCOL_CHANNEL_ID=-1001234567890
# TELEGRAM_EXAM_PROTOCOL_DELAY_SEC=300
#
# Кому слать протокол как «руководителю» (алгоритм в exam_protocol_recipients.py):
# 1) опционально app.hr.get_exam_protocol_manager_employee_id
# 2) непосредственный руководитель из карточки (manager_employee_id)
# 3) эвристика по должности: сотрудник → руководитель подразделения (get_org_unit); начальник отдела →
#    управляющий заместитель; заместитель → директор; директор → опционально TELEGRAM_EXAM_PROTOCOL_FALLBACK_ABOVE_DIRECTOR_EMPLOYEE_ID
# 4) TELEGRAM_EXAM_DIRECTOR_EMPLOYEE_ID / TELEGRAM_EXAM_MANAGING_DEPUTY_EMPLOYEE_ID — пока нет ядра HR
# 5) TELEGRAM_EXAM_DEFAULT_MANAGER_EMPLOYEE_ID — общий fallback по employee_id
# Если у выбранного руководителя нет Telegram в HR/привязке — используется TELEGRAM_EXAM_MANAGER_CHAT_ID (chat_id).
#
# Важно: строка должна начинаться с ИМЕНИ переменной, без «#» — иначе значение не загрузится.
# Пример (подставьте свои id из ядра — тот же employee_id, что в списке сотрудников / ответе GET /api/employees):
#   TELEGRAM_EXAM_DIRECTOR_EMPLOYEE_ID=uuid-или-код-директора
#   TELEGRAM_EXAM_MANAGING_DEPUTY_EMPLOYEE_ID=uuid-заместителя
#   TELEGRAM_EXAM_DEFAULT_MANAGER_EMPLOYEE_ID=uuid-руководителя-если-нет-org-структуры
# TELEGRAM_EXAM_MANAGER_CHAT_ID — только цифры (или -100…), как TELEGRAM_DOCS_SURVEY_HR_NOTIFY_CHAT_ID.
TELEGRAM_EXAM_DIRECTOR_EMPLOYEE_ID=
TELEGRAM_EXAM_MANAGING_DEPUTY_EMPLOYEE_ID=
TELEGRAM_EXAM_DEFAULT_MANAGER_EMPLOYEE_ID=
TELEGRAM_EXAM_PROTOCOL_FALLBACK_ABOVE_DIRECTOR_EMPLOYEE_ID=
TELEGRAM_EXAM_MANAGER_CHAT_ID=

# Локальная IANA-зона: слоты опроса по документам, даты в протоколе экзамена и списке протоколов (GET /display-config).
DOCS_SURVEY_LOCAL_TIMEZONE=Asia/Almaty

# Корень клона ядра typical_infrastructure (внутри него папка `app/`). Не HTTP-маршрут, а путь на диске; слэши «/» удобны в .env.
# Важно: путь должен совпадать с тем клоном, откуда вы запускаете uvicorn. Ядро хранит SQLite относительно cwd;
# runner и telegram_worker переключают cwd на этот каталог, чтобы бот и API видели один и тот же app.db.
# Реальный путь к клону с папкой app/ (проверьте: каталог должен существовать на диске).
TYPICAL_INFRA_ROOT=D:/MyActivity/MyInfoBusiness/AiUnivercity/Stage3HR/typical_infrastructure

# --- Ниже необязательные переменные (можно добавить в `.env` при необходимости) ---
#
# Режим исходящего Telegram: mock | http. Пусто = реальный api.telegram.org
# SKILL_ASSESSMENT_TELEGRAM_OUTBOUND=mock
#
# Дедлайн оценки руководителем после завершения кейсов (в часах, по умолчанию 72)
# SKILL_ASSESSMENT_MANAGER_REVIEW_DEADLINE_HOURS=72
#
# URL текста согласия на ПДн (первое Telegram-уведомление Part1)
# DOCS_SURVEY_CONSENT_DOCUMENT_URL=https://example.org/consent-pdn
#
# Напоминание за N минут до слота опроса по документам (по умолчанию 5)
# DOCS_SURVEY_REMINDER_MINUTES_BEFORE=5
#
# Другая IANA-зона (по умолчанию в примере выше — Казахстан)
# DOCS_SURVEY_LOCAL_TIMEZONE=Europe/Moscow
#
# --- STT: голос → текст (Part 1 в браузере и голосовые ответы в Telegram на экзамене) ---
# Провайдер: mock | openai. Если не задать — при наличии ключа ниже часто выбирается openai автоматически.
# mock — без сети, в БД попадает заглушка (в протоколе не будет реального транскрипта).
# openai — API Whisper (модель whisper-1), в протокол попадает распознанный текст ответа.
#
# Ключ OpenAI (одна строка, без пробелов по краям; обычно начинается с sk- или sk-proj-):
# Скопируйте строку из https://platform.openai.com/api-keys в свой файл `.env` (не коммитьте `.env`).
# Допустимы оба имени переменной — достаточно одной из них:
#   SKILL_ASSESSMENT_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# или
#   OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Кавычки не обязательны; если в ключе есть спецсимволы, можно обернуть значение в двойные кавычки.
# Раскомментируйте две строки ниже и подставьте свой ключ:
# SKILL_ASSESSMENT_STT_PROVIDER=openai
# SKILL_ASSESSMENT_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SKILL_ASSESSMENT_STT_MAX_BYTES=26214400
#
# --- Стоимость LLM-вызовов Part 2 (USD за 1M токенов) ---
# Курс для пересчёта отчёта HR из USD в RUB:
# SKILL_ASSESSMENT_USD_TO_RUB=90
#
# Общие тарифы по умолчанию для всех шагов:
# SKILL_ASSESSMENT_LLM_INPUT_USD_PER_1M=0.40
# SKILL_ASSESSMENT_LLM_OUTPUT_USD_PER_1M=1.60
#
# Необязательные overrides по шагам (если не заданы - используются общие тарифы выше):
# SKILL_ASSESSMENT_CASE_GENERATION_INPUT_USD_PER_1M=
# SKILL_ASSESSMENT_CASE_GENERATION_OUTPUT_USD_PER_1M=
# SKILL_ASSESSMENT_CASE_EVALUATION_INPUT_USD_PER_1M=
# SKILL_ASSESSMENT_CASE_EVALUATION_OUTPUT_USD_PER_1M=
# SKILL_ASSESSMENT_SKILL_EVALUATION_INPUT_USD_PER_1M=
# SKILL_ASSESSMENT_SKILL_EVALUATION_OUTPUT_USD_PER_1M=
# SKILL_ASSESSMENT_AI_COMMISSION_INPUT_USD_PER_1M=
# SKILL_ASSESSMENT_AI_COMMISSION_OUTPUT_USD_PER_1M=
#
# Необязательно: сколько вопросов брать из плана HR для экзамена (1–32). Пусто — до 32 по плану.
# SKILL_ASSESSMENT_EXAM_QUESTION_LIMIT=5
#
# --- Оценка ответов экзамена по регламентам (не LLM) ---
# Сопоставление ответа сотрудника с текстом регламента из HR и формулировкой вопроса делается локально:
# при доступности пакета sentence-transformers — семантическая близость (эмбеддинги);
# иначе — эвристика по объёму текста. Отдельный вызов ChatGPT/GPT для этого в коде не требуется.
#
# Локальный тест без POST /telegram/bindings
# TELEGRAM_DEV_CLIENT_ID=demo_client
# TELEGRAM_DEV_EMPLOYEE_ID=demo_emp
